{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/workflow/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "node_run_id": {
      "type": ["string", "null"]
    },
    "type": {
      "$ref": "../common/enums.schema.json#/$defs/artifactType"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "storage_uri": {
      "type": "string",
      "minLength": 1
    },
    "mime_type": {
      "type": "string",
      "minLength": 1
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    }
  },
  "required": [
    "artifact_id",
    "run_id",
    "node_run_id",
    "type",
    "name",
    "storage_uri",
    "mime_type",
    "size_bytes",
    "created_at"
  ],
  "additionalProperties": false
}
