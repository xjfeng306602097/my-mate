{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/workflow/event.schema.json",
  "title": "Event",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "node_run_id": {
      "type": ["string", "null"]
    },
    "type": {
      "$ref": "../common/enums.schema.json#/$defs/eventType"
    },
    "actor_type": {
      "$ref": "../common/enums.schema.json#/$defs/actorType"
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "created_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    }
  },
  "required": [
    "event_id",
    "run_id",
    "node_run_id",
    "type",
    "actor_type",
    "actor_id",
    "payload",
    "created_at"
  ],
  "additionalProperties": false
}
