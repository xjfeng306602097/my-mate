{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/workflow/human-input.schema.json",
  "title": "Human Input Request",
  "type": "object",
  "properties": {
    "input_request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "node_run_id": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "submitted", "expired", "cancelled"]
    },
    "summary": {
      "type": "string"
    },
    "input_schema": {
      "type": "object"
    },
    "requested_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    },
    "submitted_at": {
      "oneOf": [
        { "$ref": "../common/timestamps.schema.json#/$defs/dateTime" },
        { "type": "null" }
      ]
    }
  },
  "required": [
    "input_request_id",
    "run_id",
    "node_run_id",
    "status",
    "summary",
    "input_schema",
    "requested_at",
    "submitted_at"
  ],
  "additionalProperties": false
}
