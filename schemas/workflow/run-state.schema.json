{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/workflow/run-state.schema.json",
  "title": "Run State",
  "type": "object",
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "../common/enums.schema.json#/$defs/runStatus"
    },
    "current_summary": {
      "type": "string"
    },
    "waiting_reason": {
      "type": ["string", "null"]
    },
    "blocked_reason": {
      "type": ["string", "null"]
    },
    "started_at": {
      "oneOf": [
        { "$ref": "../common/timestamps.schema.json#/$defs/dateTime" },
        { "type": "null" }
      ]
    },
    "finished_at": {
      "oneOf": [
        { "$ref": "../common/timestamps.schema.json#/$defs/dateTime" },
        { "type": "null" }
      ]
    },
    "last_event_id": {
      "type": ["string", "null"]
    }
  },
  "required": [
    "run_id",
    "status",
    "current_summary",
    "waiting_reason",
    "blocked_reason",
    "started_at",
    "finished_at",
    "last_event_id"
  ],
  "additionalProperties": false
}
