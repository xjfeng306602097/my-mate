{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/workflow/workflow-template.schema.json",
  "title": "Workflow Template",
  "type": "object",
  "properties": {
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "../common/enums.schema.json#/$defs/templateStatus"
    },
    "description": {
      "type": "string"
    },
    "workspace_scope": {
      "type": "string",
      "minLength": 1
    },
    "input_schema": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "properties": {
        "max_parallel_nodes": {
          "type": "integer",
          "minimum": 1
        },
        "default_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "budget_policy": {
          "type": "object"
        },
        "approval_policy": {
          "type": "object"
        }
      },
      "required": [
        "max_parallel_nodes",
        "default_timeout_seconds",
        "budget_policy",
        "approval_policy"
      ],
      "additionalProperties": false
    },
    "agent_profile_bindings": {
      "type": "object"
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "./workflow-node.schema.json" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "./workflow-edge.schema.json" }
    },
    "metadata": {
      "type": "object"
    },
    "created_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    },
    "published_at": {
      "oneOf": [
        { "$ref": "../common/timestamps.schema.json#/$defs/dateTime" },
        { "type": "null" }
      ]
    }
  },
  "required": [
    "template_id",
    "version",
    "name",
    "status",
    "description",
    "workspace_scope",
    "input_schema",
    "policy",
    "agent_profile_bindings",
    "nodes",
    "edges",
    "metadata",
    "created_at",
    "updated_at",
    "published_at"
  ],
  "additionalProperties": false
}
