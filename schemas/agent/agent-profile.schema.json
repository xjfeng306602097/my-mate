{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/agent/agent-profile.schema.json",
  "title": "Agent Profile",
  "type": "object",
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "openclaw_agent_id": {
      "type": "string"
    },
    "default_skills": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "disallowed_skills": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "policy_tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["active", "disabled"]
    },
    "metadata": {
      "type": "object"
    },
    "created_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    }
  },
  "required": [
    "profile_id",
    "name",
    "openclaw_agent_id",
    "default_skills",
    "allowed_tools",
    "disallowed_skills",
    "policy_tags",
    "status",
    "metadata",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
