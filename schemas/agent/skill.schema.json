{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/agent/skill.schema.json",
  "title": "Skill",
  "type": "object",
  "properties": {
    "skill_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "input_schema": {
      "type": "object"
    },
    "output_contract": {
      "type": "object"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["active", "disabled"]
    },
    "metadata": {
      "type": "object"
    },
    "created_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    },
    "updated_at": {
      "$ref": "../common/timestamps.schema.json#/$defs/dateTime"
    }
  },
  "required": [
    "skill_id",
    "name",
    "description",
    "category",
    "allowed_tools",
    "input_schema",
    "output_contract",
    "tags",
    "status",
    "metadata",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
