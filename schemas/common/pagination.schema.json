{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://my-mate.local/schemas/common/pagination.schema.json",
  "title": "Pagination Envelope",
  "type": "object",
  "properties": {
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "page_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200
    },
    "total": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": ["page", "page_size", "total"],
  "additionalProperties": false
}
